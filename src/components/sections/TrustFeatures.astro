---
import SectionHeading from "@components/ui/SectionHeading.astro";
import { differentiators } from "@data/site";
import {
  HeartHandshake,
  ReceiptText,
  ShieldCheck,
  Store,
  Timer,
  UserCheck,
  type LucideProps,
} from "lucide-react";
import type { FunctionComponent } from "react";

type Props = {
  title?: string;
  subtitle?: string;
  eyebrow?: string;
};

const {
  title = "The Jim Dandy Difference",
  subtitle = "Six promises behind every job, from a leaky faucet to a full sewer replacement.",
  eyebrow,
} = Astro.props;

const iconMap: Record<string, FunctionComponent<LucideProps>> = {
  shield: ShieldCheck,
  receipt: ReceiptText,
  store: Store,
  timer: Timer,
  "user-check": UserCheck,
  handshake: HeartHandshake,
};
---

<section class="bg-surface py-20 lg:py-28">
  <div class="container-page flex flex-col gap-14">
    <div data-reveal>
      <SectionHeading title={title} subtitle={subtitle} eyebrow={eyebrow} />
    </div>

    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3" data-reveal-group>
      {differentiators.map((item, index) => {
        const Icon = iconMap[item.icon] ?? ShieldCheck;
        return (
          <div class="group relative flex flex-col gap-4 overflow-hidden rounded-[28px] border border-navy-200 bg-white p-7 shadow-sm transition-all duration-300 ease-brand hover:-translate-y-1.5 hover:border-navy-800 hover:shadow-card">
            <span class="absolute inset-x-0 top-0 h-1 origin-left scale-x-0 bg-gradient-to-r from-brand-green-500 to-brand-green-400 transition-transform duration-300 ease-brand group-hover:scale-x-100" aria-hidden="true"></span>
            <div class="flex items-center justify-between">
              <span class="grid h-14 w-14 place-items-center rounded-2xl bg-brand-green-50 text-brand-green-600 transition-colors duration-300 group-hover:bg-brand-green-500 group-hover:text-navy-900">
                <Icon className="h-7 w-7" strokeWidth={1.75} aria-hidden="true" />
              </span>
              <span class="font-badge text-3xl font-bold text-navy-100 transition-colors duration-300 group-hover:text-navy-200">
                0{index + 1}
              </span>
            </div>
            <h3 class="font-display text-xl font-bold text-navy-800">{item.title}</h3>
            <p class="text-sm leading-relaxed text-navy-600">{item.description}</p>
          </div>
        );
      })}
    </div>
  </div>
</section>

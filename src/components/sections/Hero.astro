---
import Button from "@components/ui/Button.astro";
import AnimatedCounter from "@components/ui/AnimatedCounter";
import YearsBadge from "@components/ui/YearsBadge.astro";
import RotatingHeadline from "./RotatingHeadline";
import { business } from "@data/site";
---

<section class="relative overflow-hidden bg-navy-800">
  <div class="absolute inset-0 lg:hidden" aria-hidden="true">
    <video
      class="hero-video h-full w-full object-cover opacity-[0.3]"
      autoplay
      muted
      loop
      playsinline
      preload="auto"
      poster="/hero/seattle-hero-poster.jpg"
    >
      <source src="/hero/seattle-hero.mp4" type="video/mp4" />
    </video>
    <div class="absolute inset-0 bg-gradient-to-b from-navy-900/55 via-navy-800/65 to-navy-900/90"></div>
  </div>

  <div
    class="pointer-events-none absolute inset-0 opacity-40"
    style="background: radial-gradient(600px circle at 15% 20%, rgba(105,190,40,0.18), transparent 60%), radial-gradient(500px circle at 85% 80%, rgba(105,190,40,0.12), transparent 60%);"
    aria-hidden="true"
  ></div>

  <div
    class="pointer-events-none absolute inset-y-8 -right-[80px] z-10 hidden w-[calc(48%+140px)] -translate-y-[40px] items-center justify-end lg:flex xl:w-[calc(44%+140px)]"
    aria-hidden="true"
  >
    <div
      class="hero-video-frame pointer-events-auto relative aspect-[4090/3000] w-full transition-transform duration-500 ease-out will-change-transform hover:-translate-y-2 hover:scale-[1.02]"
      style="--frame-mask: url('/NEW/Header.webp');"
    >
      <div
        class="hero-video-fill absolute inset-0"
        style="background: url('/NEW/Header.webp') center / cover no-repeat;"
      >
        <video
          class="hero-video hero-frame-video absolute inset-0 h-full w-full object-cover"
          autoplay
          muted
          loop
          playsinline
          preload="auto"
          poster="/hero/seattle-hero-poster.jpg"
        >
          <source src="/hero/seattle-hero.mp4" type="video/mp4" />
        </video>
      </div>
    </div>
  </div>

  <div class="container-page relative grid grid-cols-1 items-center gap-12 py-16 lg:grid-cols-[1fr_1fr] lg:py-24">
    <div class="flex flex-col items-start gap-10 lg:max-w-xl">
      <div class="flex flex-col gap-6">
        <RotatingHeadline
          client:load
          className="font-display text-[42px] font-black italic leading-[1.05] tracking-tight text-cloud sm:text-[56px] lg:text-[78px]"
        />
        <p class="max-w-lg text-lg leading-relaxed text-white/80 sm:text-xl">
          Licensed experts available 24/7 - from burst pipes to full sewer replacement.
          Upfront pricing, no surprises.
        </p>
      </div>

      <div class="grid w-full grid-cols-1 gap-4 sm:inline-grid sm:w-auto sm:grid-cols-2">
        <Button href={business.scheduleUrl} variant="primary" fullWidth>Schedule Online</Button>
        <Button href={business.financingUrl} variant="secondary" fullWidth>Get Financed</Button>
      </div>

      <div class="flex flex-wrap items-center gap-8">
        <div class="inline-flex items-center gap-3 border-b border-brand-green-600/40 pb-2">
          <svg viewBox="0 0 24 24" class="h-8 w-8 shrink-0" aria-hidden="true">
            <path fill="#4285F4" d="M23.52 12.27c0-.85-.08-1.67-.22-2.45H12v4.64h6.47a5.53 5.53 0 0 1-2.4 3.63v3h3.88c2.27-2.09 3.57-5.17 3.57-8.82z"/>
            <path fill="#34A853" d="M12 24c3.24 0 5.96-1.07 7.95-2.91l-3.88-3c-1.08.72-2.46 1.15-4.07 1.15-3.13 0-5.78-2.11-6.73-4.96H1.27v3.1A12 12 0 0 0 12 24z"/>
            <path fill="#FBBC05" d="M5.27 14.28A7.2 7.2 0 0 1 4.89 12c0-.79.14-1.56.38-2.28v-3.1H1.27A12 12 0 0 0 0 12c0 1.94.46 3.77 1.27 5.38z"/>
            <path fill="#EA4335" d="M12 4.75c1.77 0 3.35.61 4.6 1.8l3.44-3.44C17.95 1.19 15.24 0 12 0 7.31 0 3.26 2.69 1.27 6.62l4 3.1C6.22 6.86 8.87 4.75 12 4.75z"/>
          </svg>
          <div class="flex items-center gap-1.5">
            <span class="font-accent text-lg font-extrabold text-[#fea500]">
              <AnimatedCounter client:load target={business.rating.value} decimals={1} />
            </span>
            <div class="flex" aria-hidden="true">
              {Array.from({ length: 5 }).map(() => (
                <svg viewBox="0 0 20 20" class="h-5 w-5 fill-[#fea500]"><path d="M10 1.5l2.6 5.6 6.1.7-4.5 4.2 1.2 6-5.4-3-5.4 3 1.2-6-4.5-4.2 6.1-.7z"/></svg>
              ))}
            </div>
            <span class="sr-only">{business.rating.value} out of 5 stars from {business.rating.count} Google reviews</span>
          </div>
        </div>

        <YearsBadge years={business.yearsInBusiness} year={business.founded} class="h-[131px] w-[131px] shrink-0" />
      </div>
    </div>
  </div>
</section>

<style>
  .hero-video-frame {
    filter: drop-shadow(0 24px 36px rgba(0, 0, 0, 0.5));
  }

  /* Clip the video to the same frame shape, scaled down just enough that the
     real textured border from the frame image shows evenly all the way around. */
  .hero-frame-video {
    -webkit-mask-image: var(--frame-mask);
    mask-image: var(--frame-mask);
    -webkit-mask-size: 95.5% 95.5%;
    mask-size: 95.5% 95.5%;
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    -webkit-mask-position: center;
    mask-position: center;
  }
</style>

<script>
  if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    document.querySelectorAll<HTMLVideoElement>(".hero-video").forEach((video) => {
      video.removeAttribute("autoplay");
      video.pause();
    });
  }
</script>

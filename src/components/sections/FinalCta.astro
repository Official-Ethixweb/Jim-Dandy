---
import { Image } from "astro:assets";
import SectionHeading from "@components/ui/SectionHeading.astro";
import Button from "@components/ui/Button.astro";
import finalCtaPhoto from "@assets/photos/legacy-crew-framed.webp";
import { business } from "@data/site";
---

<section class="relative overflow-hidden bg-white py-20 lg:py-28">
  <div
    class="pointer-events-none absolute inset-0"
    style="background: radial-gradient(120% 100% at 12% 45%,
      rgba(220,255,194,0.95) 0%,
      rgba(220,255,194,0.7) 30%,
      rgba(220,255,194,0.35) 50%,
      rgba(220,255,194,0.1) 68%,
      rgba(220,255,194,0) 82%);"
    aria-hidden="true"
  ></div>

  <div class="container-page relative flex flex-col gap-12">
    <SectionHeading
      title="Ready to Fix Your Plumbing Problem?"
      subtitle={`Jim Dandy has served Seattle since ${business.founded}. We're available 24/7 - call or schedule online.`}
    />

    <div class="grid grid-cols-1 items-center gap-10 lg:grid-cols-[auto_1fr] lg:[min-height:clamp(255px,27.6vw,706px)]">
      <div class="relative grid grid-cols-2 gap-3 sm:flex sm:flex-row sm:gap-4 lg:flex-col lg:w-72">
        <div
          class="pointer-events-none absolute -inset-10 -z-10 rounded-full opacity-80 blur-3xl"
          style="background: radial-gradient(circle, rgba(105,190,40,0.16), rgba(105,190,40,0) 70%);"
          aria-hidden="true"
        ></div>
        <Button href={business.scheduleUrl} variant="primary" fullWidth class="max-sm:px-3 max-sm:text-sm">Schedule Online</Button>
        <Button href={business.financingUrl} variant="secondary" fullWidth class="max-sm:px-3 max-sm:text-sm">Get Financed</Button>
      </div>

      <Image
        src={finalCtaPhoto}
        alt="The full Jim Dandy Sewer & Plumbing crew standing together in front of a service truck"
        width={5505}
        height={2196}
        loading="lazy"
        class="h-auto lg:hidden ml-[calc(1.25rem-10%)] mr-0 w-[125%] max-w-none md:mx-[-1.25rem] md:w-[calc(100%+2.5rem)] md:max-w-full"
      />
    </div>
  </div>

  <div class="pointer-events-none absolute -right-[50px] hidden lg:block lg:bottom-28 lg:[width:clamp(630px,calc(60.5vw_+_70px),1620px)]" aria-hidden="true">
    <Image
      src={finalCtaPhoto}
      alt=""
      width={5505}
      height={2196}
      loading="lazy"
      class="pointer-events-auto h-auto w-full transition-all duration-500 ease-out will-change-transform hover:-translate-y-2 hover:scale-[1.03] hover:drop-shadow-[0_25px_50px_rgba(105,190,40,0.45)]"
    />
  </div>
</section>

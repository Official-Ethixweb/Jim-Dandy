---
import SectionHeading from "@components/ui/SectionHeading.astro";

type Step = { title: string; description: string };

type Props = {
  title?: string;
  subtitle?: string;
  eyebrow?: string;
  steps: Step[];
  tone?: "white" | "surface";
};

const {
  title = "How It Works",
  subtitle,
  eyebrow,
  steps,
  tone = "white",
} = Astro.props;

const bg = tone === "surface" ? "bg-surface" : "bg-white";
const cardBg = tone === "surface" ? "bg-white" : "bg-surface";
---

<section class:list={[bg, "py-20 lg:py-28"]}>
  <div class="container-page flex flex-col gap-14">
    <div data-reveal>
      <SectionHeading title={title} subtitle={subtitle} eyebrow={eyebrow} />
    </div>

    <ol class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4" data-reveal-group>
      {steps.map((step, index) => (
        <li class="group relative flex flex-col gap-4">
          {index < steps.length - 1 && (
            <span
              class="absolute left-[46px] top-7 hidden w-[calc(100%-30px)] border-t border-dashed border-navy-300 lg:block"
              aria-hidden="true"
            ></span>
          )}
          <div
            class:list={[
              cardBg,
              "relative flex h-full flex-col gap-3 rounded-[26px] border border-navy-200 p-7 transition-all duration-300 ease-brand hover:-translate-y-1.5 hover:border-navy-800 hover:shadow-card",
            ]}
          >
            <div class="flex items-center gap-3">
              <span class="grid h-11 w-11 shrink-0 place-items-center rounded-full bg-navy-900 font-display text-lg font-bold text-white transition-colors duration-300 group-hover:bg-brand-green-500 group-hover:text-navy-900">
                {index + 1}
              </span>
              <span class="h-px flex-1 bg-navy-100"></span>
            </div>
            <h3 class="font-display text-xl font-bold leading-tight text-navy-800">{step.title}</h3>
            <p class="text-sm leading-relaxed text-navy-600">{step.description}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

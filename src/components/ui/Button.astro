---
type Props = {
  href?: string;
  variant?: "primary" | "secondary" | "ghost";
  size?: "md" | "lg";
  class?: string;
  type?: "button" | "submit";
  fullWidth?: boolean;
  external?: boolean;
};

const {
  href,
  variant = "primary",
  size = "lg",
  class: className = "",
  type = "button",
  fullWidth = false,
  external = false,
} = Astro.props;

const Tag = href ? "a" : "button";

// Typography mirrors the approved "Schedule Online" form button (ContactForm's
// SubmitState): Barlow Condensed regular 21px, leading-none, normal tracking. Only
// the padding differs between sizes so smaller pills keep their footprint.
const base =
  "group relative inline-flex items-center justify-center gap-2 rounded-full font-display text-[21px] font-normal leading-none transition-all duration-200 ease-brand will-change-transform hover:-translate-y-0.5 active:translate-y-0 focus-visible:outline-offset-4";

const sizes = {
  md: "px-9 py-3",
  lg: "px-12 py-4",
};

// Colours sampled straight from the Figma exports (Components/Button/*/Idle
// State.png), reading a column clear of both the label and the pill's curve.
// The design ramps vertically from a light top to a soft mid-green/slate and
// never reaches the near-black the old 135deg gradients ended on - that hard,
// saturated foot is what made the buttons read flat. Hover darkens the fill and
// lifts the glow, matching Hover State.png.
const variants = {
  primary:
    "text-navy-900 bg-[image:var(--btn-primary)] shadow-[var(--shadow-btn-green)] border border-brand-green-600/30 hover:bg-[image:var(--btn-primary-hover)] hover:shadow-[var(--shadow-btn-green-hover)]",
  secondary:
    "text-white bg-[image:var(--btn-secondary)] shadow-[var(--shadow-btn-navy)] border border-navy-900/40 hover:bg-[image:var(--btn-secondary-hover)] hover:shadow-[var(--shadow-btn-navy-hover)]",
  ghost:
    "text-navy-800 bg-white/90 border border-navy-200 shadow-sm hover:bg-white",
};
---

<Tag
  href={href}
  type={!href ? type : undefined}
  target={external ? "_blank" : undefined}
  rel={external ? "noopener noreferrer" : undefined}
  class:list={[base, sizes[size], variants[variant], fullWidth && "w-full", className]}
>
  <span
    class="pointer-events-none absolute inset-0 rounded-full opacity-40 mix-blend-overlay"
    style="background: radial-gradient(circle at 30% 20%, rgba(255,255,255,0.9), transparent 60%);"
    aria-hidden="true"
  ></span>
  <slot />
</Tag>

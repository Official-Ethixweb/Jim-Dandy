---
import { Image } from "astro:assets";
import { business, footerServiceLinks, footerSitemapLinks, secondaryNavLinks } from "@data/site";
import footerLogo from "@assets/logos/jim-dandy-logo-plain.webp";

const year = new Date().getFullYear();
---

<footer class="bg-navy-800 pt-16 text-white">
  <div class="container-page">
    <div class="grid grid-cols-2 gap-x-6 gap-y-10 pb-12 sm:grid-cols-2 sm:gap-12 lg:grid-cols-4">
      <div class="col-span-2 flex flex-col gap-6 lg:col-span-1">
        <a href="/" aria-label="Jim Dandy Sewer & Plumbing, Home">
          <Image src={footerLogo} alt="Jim Dandy Sewer & Plumbing" class="h-14 w-auto" />
        </a>
        <div class="flex flex-col gap-4">
          <span class="font-display text-sm font-bold uppercase tracking-[0.2em] text-white/60">
            License No.
          </span>
          <div class="flex items-center gap-3">
            {business.licenses.map((license, i) => (
              <>
                {i > 0 && <span class="h-6 w-px shrink-0 bg-white/20" aria-hidden="true"></span>}
                <span class="whitespace-nowrap rounded-full border border-white/30 px-4 py-2 font-mono text-xs font-semibold tracking-wide text-white/90">
                  {license}
                </span>
              </>
            ))}
          </div>
        </div>
      </div>

      <div>
        <h3 class="font-heading text-lg font-semibold text-white">Services</h3>
        <ul class="mt-5 flex flex-col gap-3">
          {footerServiceLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-white/75 transition-colors hover:text-white">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="font-heading text-lg font-semibold text-white">Sitemap</h3>
        <ul class="mt-5 flex flex-col gap-3">
          {[...footerSitemapLinks, ...secondaryNavLinks].map((link) => (
            <li>
              <a href={link.href} class="text-sm text-white/75 transition-colors hover:text-white">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="col-span-2 sm:col-span-1">
        <h3 class="font-heading text-lg font-semibold text-white">Contact</h3>
        <ul class="mt-5 flex flex-col gap-4 text-sm text-white/75">
          <li>
            <a href={business.phoneHref} class="font-display text-2xl font-bold text-white">
              {business.phone}
            </a>
          </li>
          <li>
            <a href={`mailto:${business.email}`} class="hover:text-white">
              {business.email}
            </a>
          </li>
          <li>
            {business.address.full}
          </li>
          <li>
            {business.hours}
          </li>
        </ul>
        <div class="mt-5 flex gap-3">
          <a
            href={business.social.facebook}
            aria-label="Jim Dandy on Facebook"
            class="grid h-10 w-10 place-items-center rounded-full bg-white/10 transition-colors hover:bg-brand-green-500 hover:text-navy-900"
          >
            <svg viewBox="0 0 24 24" class="h-8 w-8" fill="currentColor" aria-hidden="true">
              <path d="M22 12.06C22 6.5 17.52 2 12 2S2 6.5 2 12.06C2 17.08 5.66 21.23 10.44 22v-7.03H7.9v-2.91h2.54V9.85c0-2.51 1.49-3.9 3.77-3.9 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56v1.88h2.78l-.44 2.91h-2.34V22C18.34 21.23 22 17.08 22 12.06z" />
            </svg>
          </a>
          <a
            href={business.social.google}
            aria-label="Jim Dandy on Google"
            class="grid h-10 w-10 place-items-center rounded-full bg-white/10 text-3xl font-bold transition-colors hover:bg-brand-green-500 hover:text-navy-900"
          >
            G
          </a>
        </div>
      </div>
    </div>

  </div>
  <div class="bg-brand-green-500">
    <div class="container-page flex flex-col items-center justify-between gap-2 py-2 text-xs font-semibold text-navy-900 sm:flex-row">
      <p>Copyrighted © {year} {business.name} | All Rights Reserved</p>
      <div class="flex items-center gap-4">
        <a href="/privacy-policy" class="underline hover:text-navy-700">Privacy Policy</a>
        <a href="/terms" class="underline hover:text-navy-700">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>

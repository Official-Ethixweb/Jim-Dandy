---
import Layout from "@layouts/Layout.astro";
import Button from "@components/ui/Button.astro";
import SectionHeading from "@components/ui/SectionHeading.astro";
import PageHero from "@components/sections/PageHero.astro";
import ProcessSteps from "@components/sections/ProcessSteps.astro";
import FinalCta from "@components/sections/FinalCta.astro";
import MotionInit from "@components/ui/MotionInit.astro";
import StickyCta from "@components/ui/StickyCta.astro";
import { business } from "@data/site";
import { coupons } from "@data/coupons";
import { breadcrumbSchema } from "@lib/seo";
import { Scissors, Tag } from "lucide-react";

const crumbs = breadcrumbSchema([
  { name: "Home", path: "/" },
  { name: "Coupons", path: "/coupons" },
]);

const redeemSteps = [
  { title: "Pick Your Offer", description: "Browse the current coupons below and choose the one that fits your repair or install." },
  { title: "Mention It When You Book", description: "Tell your dispatcher or technician which offer you'd like to use when you schedule." },
  { title: "Save on Your Invoice", description: "We apply the discount to your final bill - just ask if you qualify for more than one." },
];
---

<Layout
  title="Coupons & Specials | Jim Dandy Sewer & Plumbing"
  description="Current plumbing and sewer service coupons from Jim Dandy Sewer & Plumbing - savings on repairs, new customer discounts, and free inspections."
  path="/coupons"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(crumbs)} slot="head" />

  <PageHero
    eyebrow="Save With Jim Dandy"
    title="Coupons & Seasonal Specials"
    lead="Real savings on trusted plumbing and sewer work. Mention any offer below when you call or schedule online - and ask your technician if you qualify for more than one."
    crumbs={[{ name: "Home", href: "/" }, { name: "Coupons" }]}
    ctas={[
      { label: "Schedule & Save", href: business.scheduleUrl, variant: "primary" },
      { label: `Call ${business.phone}`, href: business.phoneHref, variant: "secondary" },
    ]}
  />

  <!-- Coupon tickets -->
  <section class="bg-surface py-20 lg:py-28">
    <div class="container-page flex flex-col gap-14">
      <div data-reveal>
        <SectionHeading eyebrow="Current Offers" title="Clip & Save" subtitle="Valid for service within our Puget Sound coverage area." />
      </div>
      <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3" data-reveal-group>
        {coupons.map((coupon) => (
          <article class="group relative flex flex-col overflow-hidden rounded-[28px] border border-navy-200 bg-white shadow-card transition-transform duration-300 ease-brand hover:-translate-y-1.5">
            <div class="flex flex-col gap-4 p-8">
              <div class="flex items-center justify-between">
                <span class="grid h-12 w-12 place-items-center rounded-2xl bg-brand-green-50 text-brand-green-600 transition-colors duration-300 group-hover:bg-brand-green-500 group-hover:text-navy-900">
                  <Tag className="h-6 w-6" aria-hidden="true" />
                </span>
                <span class="inline-flex items-center gap-1.5 rounded-full bg-navy-900 px-3 py-1.5 text-[11px] font-bold uppercase tracking-wider text-brand-green-400">
                  <Scissors className="h-3.5 w-3.5" aria-hidden="true" /> Coupon
                </span>
              </div>
              <h3 class="font-display text-2xl font-bold leading-tight text-navy-800">{coupon.title}</h3>
              <p class="text-base leading-relaxed text-navy-600">{coupon.description}</p>
            </div>

            <div class="relative px-6" aria-hidden="true">
              <span class="absolute -left-3 top-1/2 h-6 w-6 -translate-y-1/2 rounded-full bg-surface"></span>
              <span class="absolute -right-3 top-1/2 h-6 w-6 -translate-y-1/2 rounded-full bg-surface"></span>
              <div class="border-t-2 border-dashed border-navy-200"></div>
            </div>

            <div class="flex flex-col gap-4 p-8 pt-6">
              <p class="text-xs leading-relaxed text-navy-400">{coupon.terms}</p>
              <Button href={business.scheduleUrl} variant="ghost" size="md" class="self-start">Redeem This Offer</Button>
            </div>
          </article>
        ))}
      </div>
      <p class="text-center text-sm text-navy-400">
        Offers subject to change without notice. Call {business.phone} to confirm current promotions before your appointment.
      </p>
    </div>
  </section>

  <ProcessSteps
    eyebrow="Easy to Use"
    title="How to Redeem"
    subtitle="Three simple steps between you and a lower invoice."
    steps={redeemSteps}
  />

  <FinalCta />

  <StickyCta />
  <MotionInit />
</Layout>

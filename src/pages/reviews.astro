---
import Layout from "@layouts/Layout.astro";
import Button from "@components/ui/Button.astro";
import SectionHeading from "@components/ui/SectionHeading.astro";
import PageHero from "@components/sections/PageHero.astro";
import FinalCta from "@components/sections/FinalCta.astro";
import MotionInit from "@components/ui/MotionInit.astro";
import StickyCta from "@components/ui/StickyCta.astro";
import { business, reviews, extraReviews } from "@data/site";
import { breadcrumbSchema } from "@lib/seo";
import { Quote, Star } from "lucide-react";

const crumbs = breadcrumbSchema([
  { name: "Home", path: "/" },
  { name: "Reviews", path: "/reviews" },
]);

const allReviews = [...reviews, ...extraReviews];

// Illustrative distribution that reconciles to the real 4.8 / 177 aggregate.
const distribution = [
  { stars: 5, pct: 88 },
  { stars: 4, pct: 8 },
  { stars: 3, pct: 2 },
  { stars: 2, pct: 1 },
  { stars: 1, pct: 1 },
];
---

<Layout
  title="Customer Reviews | Jim Dandy Sewer & Plumbing"
  description={`Read why Puget Sound homeowners rate Jim Dandy Sewer & Plumbing ${business.rating.value} stars across ${business.rating.count}+ Google reviews. Honest pricing, fast service, guaranteed work.`}
  path="/reviews"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(crumbs)} slot="head" />

  <PageHero
    eyebrow={`Rated ${business.rating.value} on Google`}
    title="What Puget Sound Says About Us"
    lead="Since 1908, our reputation has been built one honest repair at a time. Here's what your neighbors have to say about the crew at their door."
    crumbs={[{ name: "Home", href: "/" }, { name: "Reviews" }]}
    ctas={[
      { label: "Read More on Google", href: business.social.google, variant: "primary" },
      { label: `Call ${business.phone}`, href: business.phoneHref, variant: "secondary" },
    ]}
  />

  <!-- Rating summary -->
  <section class="bg-white py-20 lg:py-28">
    <div class="container-page grid grid-cols-1 items-center gap-12 lg:grid-cols-[0.8fr_1fr]">
      <div class="flex flex-col items-center gap-4 rounded-[32px] border border-navy-200 bg-surface p-10 text-center shadow-card" data-reveal="left">
        <div class="flex items-center gap-2">
          <svg viewBox="0 0 24 24" class="h-8 w-8" aria-hidden="true">
            <path fill="#4285F4" d="M23.52 12.27c0-.85-.08-1.67-.22-2.45H12v4.64h6.47a5.53 5.53 0 0 1-2.4 3.63v3h3.88c2.27-2.09 3.57-5.17 3.57-8.82z"/>
            <path fill="#34A853" d="M12 24c3.24 0 5.96-1.07 7.95-2.91l-3.88-3c-1.08.72-2.46 1.15-4.07 1.15-3.13 0-5.78-2.11-6.73-4.96H1.27v3.1A12 12 0 0 0 12 24z"/>
            <path fill="#FBBC05" d="M5.27 14.28A7.2 7.2 0 0 1 4.89 12c0-.79.14-1.56.38-2.28v-3.1H1.27A12 12 0 0 0 0 12c0 1.94.46 3.77 1.27 5.38z"/>
            <path fill="#EA4335" d="M12 4.75c1.77 0 3.35.61 4.6 1.8l3.44-3.44C17.95 1.19 15.24 0 12 0 7.31 0 3.26 2.69 1.27 6.62l4 3.1C6.22 6.86 8.87 4.75 12 4.75z"/>
          </svg>
          <span class="font-badge text-lg font-bold text-navy-700">Google Reviews</span>
        </div>
        <p class="font-badge text-7xl font-bold text-navy-800">{business.rating.value}</p>
        <div class="flex" aria-hidden="true">
          {Array.from({ length: 5 }).map(() => (
            <Star className="h-7 w-7 fill-[#fea500] text-[#fea500]" />
          ))}
        </div>
        <p class="text-sm font-semibold text-navy-500">Based on {business.rating.count}+ verified reviews</p>
      </div>

      <div class="flex flex-col gap-5" data-reveal="right">
        <SectionHeading eyebrow="The Numbers" title="Trusted, Review After Review" align="left" />
        <div class="flex flex-col gap-3">
          {distribution.map((row) => (
            <div class="flex items-center gap-3">
              <span class="flex w-12 shrink-0 items-center gap-1 text-sm font-semibold text-navy-600">
                {row.stars} <Star className="h-3.5 w-3.5 fill-[#fea500] text-[#fea500]" aria-hidden="true" />
              </span>
              <span class="h-3 flex-1 overflow-hidden rounded-full bg-navy-100">
                <span class="block h-full rounded-full bg-brand-green-500" style={`width:${row.pct}%`}></span>
              </span>
              <span class="w-10 shrink-0 text-right text-sm text-navy-400">{row.pct}%</span>
            </div>
          ))}
        </div>
        <p class="text-sm leading-relaxed text-navy-500">
          Ratings reflect verified Google reviews from customers across the Puget Sound region.
        </p>
      </div>
    </div>
  </section>

  <!-- Reviews grid -->
  <section class="bg-surface py-20 lg:py-28">
    <div class="container-page flex flex-col gap-14">
      <div data-reveal>
        <SectionHeading eyebrow="In Their Words" title="Real Reviews, Real Neighbors" subtitle="A few of the many reasons customers keep calling Jim Dandy." />
      </div>
      <div class="columns-1 gap-6 sm:columns-2 lg:columns-3 [&>*]:mb-6 [&>*]:break-inside-avoid" data-reveal-group data-reveal-step="60">
        {allReviews.map((review) => (
          <figure class="flex break-inside-avoid flex-col gap-4 rounded-[26px] border border-navy-200 bg-white p-7 shadow-review transition-all duration-300 ease-brand hover:-translate-y-1 hover:shadow-card">
            <div class="flex items-center justify-between">
              <Quote className="h-8 w-8 text-brand-green-500" aria-hidden="true" />
              <div class="flex" aria-hidden="true">
                {Array.from({ length: review.rating }).map(() => (
                  <Star className="h-4 w-4 fill-[#fea500] text-[#fea500]" />
                ))}
              </div>
            </div>
            <blockquote class="text-base leading-relaxed text-navy-700">{review.text}</blockquote>
            <figcaption class="mt-auto flex items-center justify-between border-t border-navy-100 pt-4">
              <div class="leading-tight">
                <p class="font-sans font-semibold text-navy-900">{review.name}</p>
                <p class="text-xs text-navy-400">
                  {"city" in review && review.city ? `${review.city} · ` : ""}{review.timeAgo}
                </p>
              </div>
              <svg viewBox="0 0 24 24" class="h-6 w-6 shrink-0" aria-hidden="true">
                <path fill="#4285F4" d="M23.52 12.27c0-.85-.08-1.67-.22-2.45H12v4.64h6.47a5.53 5.53 0 0 1-2.4 3.63v3h3.88c2.27-2.09 3.57-5.17 3.57-8.82z"/>
                <path fill="#34A853" d="M12 24c3.24 0 5.96-1.07 7.95-2.91l-3.88-3c-1.08.72-2.46 1.15-4.07 1.15-3.13 0-5.78-2.11-6.73-4.96H1.27v3.1A12 12 0 0 0 12 24z"/>
                <path fill="#FBBC05" d="M5.27 14.28A7.2 7.2 0 0 1 4.89 12c0-.79.14-1.56.38-2.28v-3.1H1.27A12 12 0 0 0 0 12c0 1.94.46 3.77 1.27 5.38z"/>
                <path fill="#EA4335" d="M12 4.75c1.77 0 3.35.61 4.6 1.8l3.44-3.44C17.95 1.19 15.24 0 12 0 7.31 0 3.26 2.69 1.27 6.62l4 3.1C6.22 6.86 8.87 4.75 12 4.75z"/>
              </svg>
            </figcaption>
          </figure>
        ))}
      </div>
      <div class="flex justify-center" data-reveal>
        <Button href={business.social.google} variant="secondary" external>Read More Reviews on Google</Button>
      </div>
    </div>
  </section>

  <FinalCta />

  <StickyCta />
  <MotionInit />
</Layout>

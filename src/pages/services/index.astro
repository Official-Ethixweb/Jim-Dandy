---
import Layout from "@layouts/Layout.astro";
import PageHero from "@components/sections/PageHero.astro";
import ServicesGrid from "@components/sections/ServicesGrid.astro";
import StatBand from "@components/sections/StatBand.astro";
import TrustFeatures from "@components/sections/TrustFeatures.astro";
import ProcessSteps from "@components/sections/ProcessSteps.astro";
import FaqSection from "@components/sections/FaqSection.astro";
import ReviewsSection from "@components/sections/ReviewsSection.astro";
import FinalCta from "@components/sections/FinalCta.astro";
import MotionInit from "@components/ui/MotionInit.astro";
import StickyCta from "@components/ui/StickyCta.astro";
import { howItWorks } from "@data/site";
import { breadcrumbSchema } from "@lib/seo";
import heroPhoto from "@assets/photos/legacy-crew-truck.webp";

const crumbs = breadcrumbSchema([
  { name: "Home", path: "/" },
  { name: "Services", path: "/services" },
]);

const processSteps = howItWorks.map((s) => ({ title: s.title, description: s.description }));
---

<Layout
  title="Plumbing Services | Jim Dandy Sewer & Plumbing"
  description="Emergency plumbing, drain cleaning, sewer repair, water heaters, and full-service plumbing across the Puget Sound region. Licensed, insured, available 24/7."
  path="/services"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(crumbs)} slot="head" />

  <PageHero
    eyebrow="Plumbing & Sewer Experts"
    title="Every Job. One Trusted Team."
    lead="From same-hour emergencies to planned upgrades, our licensed technicians cover the full range of residential and commercial plumbing - with upfront pricing every single time."
    image={heroPhoto}
    imageAlt="A Jim Dandy technician standing in front of a company service van"
    crumbs={[{ name: "Home", href: "/" }, { name: "Services" }]}
  />

  <ServicesGrid />

  <StatBand />

  <TrustFeatures
    eyebrow="Why Homeowners Call Us"
    title="Premium Service, Honest Prices"
    subtitle="What you can count on from Jim Dandy, whether it's a dripping faucet or a full sewer replacement."
  />

  <ProcessSteps
    eyebrow="Simple Process"
    title="How Jim Dandy Works"
    subtitle="Four straightforward steps from your first call to a problem solved."
    steps={processSteps}
  />

  <FaqSection />

  <ReviewsSection />

  <FinalCta />

  <StickyCta />
  <MotionInit />
</Layout>

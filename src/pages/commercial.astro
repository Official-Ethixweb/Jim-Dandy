---
import Layout from "@layouts/Layout.astro";
import Button from "@components/ui/Button.astro";
import SectionHeading from "@components/ui/SectionHeading.astro";
import Heading from "@components/ui/Heading.astro";
import PageHero from "@components/sections/PageHero.astro";
import ProcessSteps from "@components/sections/ProcessSteps.astro";
import Accordion from "@components/sections/Accordion";
import FinalCta from "@components/sections/FinalCta.astro";
import MotionInit from "@components/ui/MotionInit.astro";
import StickyCta from "@components/ui/StickyCta.astro";
import { business, serviceExtras } from "@data/site";
import { breadcrumbSchema, faqSchema } from "@lib/seo";
import { Building2, CheckCircle2, ClipboardList, Clock, Store, UtensilsCrossed } from "lucide-react";
import heroPhoto from "@assets/photos/legacy-jd-truck.webp";

const propertyTypes = [
  { label: "Multi-Family & Apartments", description: "Buildings, HOAs, and portfolios with shared systems and tenants who can't wait.", icon: Building2 },
  { label: "Restaurants & Food Service", description: "Grease traps, high-use drains, and code compliance kept ahead of inspection day.", icon: UtensilsCrossed },
  { label: "Retail & Office Buildings", description: "Clean, discreet service scheduled around your customers and business hours.", icon: Store },
  { label: "Property Management", description: "One reliable vendor and clear invoicing across every property you manage.", icon: ClipboardList },
];

const commercialServices = [
  "Preventive maintenance contracts scheduled around your business hours",
  "Grease trap pumping, service, and code compliance",
  "Backflow testing and certification",
  "Priority 24/7 emergency response for commercial accounts",
  "Commercial water heater and boiler service",
  "Sewer and drain line maintenance for high-use buildings",
];

const whyUs = [
  { label: "Priority Emergency Response", description: "Commercial accounts get priority dispatch - a plumbing issue doesn't get to become a closed sign." },
  { label: "Licensed & Insured Crews", description: "Every technician is a licensed Washington State plumber; Jim Dandy carries full bonding and insurance." },
  { label: "Clear, Itemized Invoicing", description: "Detailed invoices built for property management and accounting workflows, not handwritten receipts." },
  { label: "118 Years in Puget Sound", description: "We've kept local businesses running since 1908 - long enough to know how to keep yours open." },
];

const extra = serviceExtras.commercial;

const crumbs = breadcrumbSchema([
  { name: "Home", path: "/" },
  { name: "Commercial", path: "/commercial" },
]);
---

<Layout
  title="Commercial Plumbing Services | Jim Dandy Sewer & Plumbing"
  description="Scheduled maintenance and 24/7 emergency response for restaurants, multi-family properties, and commercial buildings across the Puget Sound region."
  path="/commercial"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(crumbs)} slot="head" />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema(extra.faqs))} slot="head" />

  <PageHero
    eyebrow="Commercial & Multi-Family"
    title="Plumbing That Keeps You Open"
    lead="Downtime costs money. We partner with property managers, restaurants, and multi-family buildings on scheduled maintenance - backed by the same 24/7 emergency response we bring to every call."
    image={heroPhoto}
    imageAlt="A branded Jim Dandy Sewer & Plumbing commercial service truck"
    crumbs={[{ name: "Home", href: "/" }, { name: "Commercial" }]}
    ctas={[
      { label: "Schedule a Consultation", href: business.scheduleUrl, variant: "primary" },
      { label: `Call ${business.phone}`, href: business.phoneHref, variant: "secondary" },
    ]}
  />

  <!-- Who we serve -->
  <section class="bg-white py-20 lg:py-28">
    <div class="container-page flex flex-col gap-14">
      <div data-reveal>
        <SectionHeading eyebrow="Who We Serve" title="Built Around Your Operating Hours" subtitle="Commercial plumbing scheduled around your business, not ours." />
      </div>
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4" data-reveal-group>
        {propertyTypes.map(({ label, description, icon: Icon }) => (
          <div class="group flex flex-col gap-4 rounded-[28px] border border-navy-200 bg-surface p-7 transition-all duration-300 ease-brand hover:-translate-y-1.5 hover:border-navy-800 hover:bg-white hover:shadow-card">
            <span class="grid h-14 w-14 place-items-center rounded-2xl bg-navy-900 text-brand-green-400 transition-colors duration-300 group-hover:bg-brand-green-500 group-hover:text-navy-900">
              <Icon className="h-7 w-7" strokeWidth={1.6} aria-hidden="true" />
            </span>
            <p class="font-display text-lg font-bold text-navy-800">{label}</p>
            <p class="text-sm leading-relaxed text-navy-600">{description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Services + Why us -->
  <section class="bg-surface py-20 lg:py-28">
    <div class="container-page grid grid-cols-1 gap-8 lg:grid-cols-2">
      <div class="flex flex-col gap-6 rounded-[32px] border border-navy-200 bg-white p-8 shadow-sm sm:p-10" data-reveal="left">
        <Heading title="Commercial Services" eyebrow="What We Handle" />
        <ul class="flex flex-col gap-4">
          {commercialServices.map((item) => (
            <li class="flex items-start gap-3 text-base leading-relaxed text-navy-700">
              <span class="mt-0.5 grid h-6 w-6 shrink-0 place-items-center rounded-full bg-brand-green-50 text-brand-green-600">
                <CheckCircle2 className="h-4 w-4" aria-hidden="true" />
              </span>
              {item}
            </li>
          ))}
        </ul>
        <Button href={business.scheduleUrl} variant="primary" class="mt-2 self-start">Request a Maintenance Plan</Button>
      </div>
      <div class="flex flex-col gap-6" data-reveal="right">
        <Heading title="Why Businesses Choose Us" eyebrow="The Difference" />
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
          {whyUs.map(({ label, description }) => (
            <div class="rounded-[24px] border border-navy-200 bg-white p-6 transition-all duration-300 ease-brand hover:-translate-y-1 hover:border-navy-800 hover:shadow-card">
              <p class="font-display text-lg font-bold text-navy-800">{label}</p>
              <p class="mt-2 text-sm leading-relaxed text-navy-600">{description}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <ProcessSteps
    eyebrow="How We Partner"
    title="From Walkthrough to Worry-Free"
    subtitle="A clear, documented process built for busy properties."
    steps={extra.process}
  />

  <!-- 24/7 band -->
  <section class="relative overflow-hidden bg-navy-900 py-16 lg:py-20">
    <div
      class="pointer-events-none absolute inset-0 opacity-50"
      style="background: radial-gradient(600px circle at 50% 0%, rgba(105,190,40,0.18), transparent 60%);"
      aria-hidden="true"
    ></div>
    <div class="container-page relative flex flex-col items-center gap-5 text-center">
      <span class="grid h-16 w-16 place-items-center rounded-2xl bg-brand-green-500/15 text-brand-green-400">
        <Clock className="h-8 w-8" aria-hidden="true" />
      </span>
      <h2 class="font-display text-3xl font-black italic text-white sm:text-4xl">24/7 Priority Emergency Dispatch</h2>
      <p class="max-w-xl leading-relaxed text-white/75">
        Commercial accounts reach a live dispatcher any hour of the day - no answering machines, no
        waiting until morning, no lost revenue.
      </p>
      <div class="mt-2 flex flex-col gap-4 sm:flex-row">
        <Button href={business.phoneHref} variant="primary">Call {business.phone}</Button>
        <Button href={business.scheduleUrl} variant="ghost">Schedule Online</Button>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-surface py-20 lg:py-28">
    <div class="container-page flex flex-col gap-14">
      <SectionHeading eyebrow="Good to Know" title="Commercial Questions, Answered" />
      <div class="mx-auto w-full max-w-3xl" data-reveal>
        <Accordion client:visible items={extra.faqs} />
      </div>
    </div>
  </section>

  <FinalCta />

  <StickyCta />
  <MotionInit />
</Layout>
